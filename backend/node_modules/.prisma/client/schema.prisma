generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  points    Int      @default(0)
  level     Int      @default(1)
  streak    Int      @default(0)
  lastQuiz  DateTime @default(now())
  answers   Answer[]
  createdAt DateTime @default(now())
}

model Question {
  id          String   @id @default(cuid())
  topic       String
  text        String
  optionsJson String
  correct     Int
  answers     Answer[]
  createdAt   DateTime @default(now())
}

model Answer {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  chosen     Int
  isCorrect  Boolean
  user       User     @relation(fields: [userId], references: [id])
  question   Question @relation(fields: [questionId], references: [id])
  createdAt  DateTime @default(now())
}
